# Database - Use either DATABASE_URL (production) or individual DB_* vars (development)
# For Vercel/Production: DATABASE_URL=mysql://user:password@host/database
DATABASE_URL=

# Development Database (if not using DATABASE_URL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=12345678Qwerty
DB_NAME=companyvoice

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL
VITE_API_BASE_URL=http://localhost:5000

# Admin
ADMIN_EMAIL=admin@companyvoice.com
ADMIN_PASSWORD=AdminPassword123
